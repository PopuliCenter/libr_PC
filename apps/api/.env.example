# ===== Aplikasi =====
PORT=3001
APP_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# ===== Database =====
# DB_TYPE: "sqlite" (dev, tanpa instalasi) atau "postgres" (produksi)
DB_TYPE=sqlite
DB_SQLITE_PATH=data/library.dev.sqlite
# Dipakai bila DB_TYPE=postgres:
DB_HOST=localhost
DB_PORT=5432
DB_USER=library
DB_PASSWORD=
DB_NAME=populi_library

# ===== Auth =====
JWT_SECRET=ganti-dengan-string-acak-panjang
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d

# Google OAuth (kosongkan bila belum dipakai — endpoint akan menjawab 503)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# ===== SSO / OpenID Connect Provider (PRD I1 — akun tunggal Populi) =====
# Perpustakaan jadi penerbit identitas untuk aplikasi survei & layanan Populi.
# Issuer OIDC (harus URL publik HTTPS di produksi). Default: ${APP_URL}/api/v1
OIDC_ISSUER=http://localhost:3001/api/v1
# Kunci RSA privat penandatangan (PEM PKCS#8, newline sebagai \n). Wajib di
# produksi bila OAUTH_CLIENTS terisi. Buat: openssl genpkey -algorithm RSA \
#   -pkeyopt rsa_keygen_bits:2048 | sed ':a;N;$!ba;s/\n/\\n/g'
# Kosong di dev => kunci sementara dibuat otomatis (token tak bertahan restart).
OIDC_PRIVATE_KEY=
OIDC_KEY_ID=populi-oidc-1
# Daftar klien OAuth (JSON array). Kosong di dev => klien "populi-survey-dev"
# diseed otomatis (redirect http://localhost:4000/auth/callback, secret dev-survey-secret).
# OAUTH_CLIENTS=[{"clientId":"populi-survey","name":"Aplikasi Survei Populi","clientSecret":"GANTI-RAHASIA","redirectUris":["https://survei.populicenter.org/auth/callback"],"scopes":["openid","profile","email","offline_access"]}]
OAUTH_CLIENTS=

# ===== OAI-PMH (Indonesia OneSearch) =====
OAI_REPOSITORY_NAME=Perpustakaan Digital Populi Center
OAI_BASE_URL=http://localhost:3001/api/v1/oai
OAI_ADMIN_EMAIL=library@populicenter.org

# ===== Notifikasi WhatsApp (PRD I5) =====
# Channel WA berjalan berdampingan dengan email untuk pengingat jatuh tempo sewa
# & giliran antrian. Dikirim hanya bila anggota mencantumkan nomor telepon.
# WA_PROVIDER: kosong => "log" di dev (tulis ke log), "none" di produksi (nonaktif).
#   Pilihan: log | none | fonnte | meta
WA_PROVIDER=
WA_DEFAULT_COUNTRY=62
# Fonnte (gateway WABA lokal) — https://fonnte.com
WA_FONNTE_TOKEN=
# WhatsApp Cloud API (Meta)
WA_META_PHONE_ID=
WA_META_TOKEN=

# ===== Chat AI =====
# Bila kosong, chat memakai mode FAQ (rule-based) tanpa AI.
ANTHROPIC_API_KEY=
CHAT_MODEL=claude-opus-4-8
