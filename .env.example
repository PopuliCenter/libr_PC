# Konfigurasi Docker Compose (salin menjadi .env lalu isi).
# Aplikasi MENOLAK START di produksi bila dua nilai wajib di bawah kosong/default.

# WAJIB — string acak panjang, mis. hasil: openssl rand -hex 32
JWT_SECRET=

# WAJIB — password superadmin awal (akun: ADMIN_EMAIL di bawah)
ADMIN_PASSWORD=

ADMIN_EMAIL=admin@populicenter.org

# Kredensial PostgreSQL (default aman untuk lokal; ganti di server)
DB_USER=library
DB_PASSWORD=library
DB_NAME=populi_library

# Penyimpanan bertingkat (opsional).
# STORAGE_COLD_DIR = titik mount NAS/QNAP untuk PDF master & berkas impor —
# data besar yang jarang dibaca, agar tidak memakan disk server.
# Cache render halaman SELALU tetap di disk lokal (STORAGE_DIR) supaya
# membalik halaman tidak menembus jaringan; isinya bisa dibuat ulang kapan saja.
# Kosongkan STORAGE_COLD_DIR untuk menaruh semuanya di disk lokal.
STORAGE_DIR=data/storage
STORAGE_COLD_DIR=
# Umur cache halaman sebelum dibersihkan otomatis (0 = jangan pernah bersihkan).
PAGE_CACHE_TTL_DAYS=30

# Opsional
ANTHROPIC_API_KEY=
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
OAI_BASE_URL=http://localhost:3001/api/v1/oai
